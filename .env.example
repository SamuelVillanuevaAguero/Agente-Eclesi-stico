# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=api_key
EMBEDDING_PROVIDER=openai

# ─── LangSmith (trazabilidad y LangGraph Studio) ──────────────────────────────
LANGCHAIN_API_KEY=lang_api_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=iglesia-universal-agente
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── Modelos ──────────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
TEMPERATURE=0.2
MAX_TOKENS=2048

# ─── Rutas ────────────────────────────────────────────────────────────────────
HYMNS_DIR=./himnos
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=himnario_icuajp

# ─── Recuperación ─────────────────────────────────────────────────────────────
MAX_RETRIEVAL_RESULTS=8

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

DELAY_SECONDS = 10